<resources>
    <!-- Base application theme (Light Mode - Dull Grey) -->
    <style name="Base.Theme.SecureNotesApp" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>

        <!-- Dull light background (not white) -->
        <item name="android:windowBackground">@color/light_bg</item>
        <item name="colorSurface">@color/light_surface</item>
        <item name="colorOnSurface">@color/light_on_bg</item>
        <item name="colorOnBackground">@color/light_on_bg</item>
        <item name="colorSurfaceVariant">@color/light_surface</item>
        <item name="colorOnSurfaceVariant">@color/light_on_bg</item>

        <item name="android:textColorPrimary">@color/light_on_bg</item>
        <item name="android:textColorSecondary">@color/light_text_sec</item>

        <item name="android:statusBarColor">@color/light_bg</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.SecureNotesApp" parent="Base.Theme.SecureNotesApp" />
</resources>