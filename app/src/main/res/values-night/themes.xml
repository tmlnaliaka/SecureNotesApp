<resources>
    <!-- Base application theme (Dark Mode - Dull Slate) -->
    <style name="Base.Theme.SecureNotesApp" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>

        <!-- Dull dark background -->
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/dark_on_bg</item>
        <item name="colorOnBackground">@color/dark_on_bg</item>
        <item name="colorSurfaceVariant">@color/dark_surface</item>
        <item name="colorOnSurfaceVariant">@color/dark_on_bg</item>

        <item name="android:textColorPrimary">@color/dark_on_bg</item>
        <item name="android:textColorSecondary">@color/dark_text_sec</item>

        <item name="android:statusBarColor">@color/dark_bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>